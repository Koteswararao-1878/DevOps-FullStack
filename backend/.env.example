# ═══════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (choose one)
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/skill-swap-platform

# MongoDB Atlas (Cloud):
MONGODB_URI=mongodb+srv://koteswararao:koti2005@projectdb.tlflonf.mongodb.net/skill-swap-platform?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=skill-swap-secret-key
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ═══════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT VARIABLES (Render/Railway/etc)
# ═══════════════════════════════════════════════════════

# For MongoDB Atlas:
# - Replace username with your MongoDB user
# - Replace password with your MongoDB password
# - Replace cluster0.abc with your actual cluster name
# - Replace skill-swap-platform with your database name

# JWT_SECRET should be a long, random string. Generate one:
# bash: openssl rand -base64 32
# or use: https://tool-online.com/en/random-string-generator.php

# FRONTEND_URL should be your production frontend domain
# Example: https://skill-swap.vercel.app
